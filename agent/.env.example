# ─── OpenRouter API Key ───────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ─── LLM Model ────────────────────────────────────────────────────────────────
# OpenRouter model name. Default: Claude Sonnet 4.6
MODEL=anthropic/claude-sonnet-4.6

# ─── ClickHouse Connection ────────────────────────────────────────────────────
# Self-hosted or cloud ClickHouse instance (port 8443, HTTPS)
# Only the hostname — no https:// prefix, no trailing slash
CLICKHOUSE_HOST=your-clickhouse-host.example.com
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=your_user
CLICKHOUSE_PASSWORD=your_password
CLICKHOUSE_DATABASE=your_database

# Path to custom CA certificate (relative to this .env file, or absolute).
# Leave empty if the server uses a trusted CA (e.g. Let's Encrypt).
# For Yandex Cloud: CLICKHOUSE_SSL_CERT_PATH=YandexInternalRootCA.crt
CLICKHOUSE_SSL_CERT_PATH=

# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_URL=https://servermagnetto.asktab.ru
HOST=0.0.0.0
PORT=8000

# ─── Optional tuning ──────────────────────────────────────────────────────────
MAX_TOKENS=8192
MAX_AGENT_ITERATIONS=15
TEMP_FILE_TTL_SECONDS=3600
